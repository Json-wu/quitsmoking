<!--pages/breathing/breathing.wxml-->
<view class="container">
  <view class="content">
    <!-- 顶部提示文字 -->
    <view class="step-text">{{ stepText }}</view>
    
    <!-- 肺部图片 -->
    <view class="lung-container">
      <image 
        class="lung-image {{ isBreathing ? 'breathing' : '' }}" 
        src="/assets/images/fb.png" 
        mode="aspectFit"
      ></image>
    </view>
    
    <!-- 倒计时提示 -->
    <view class="countdown-text" wx:if="{{ countdown > 0 }}">剩余时间{{ countdown }}秒</view>
    
    <!-- 下一步按钮 -->
    <button class="next-btn {{ countdown > 0 ? 'disabled' : '' }}" bindtap="handleNext" disabled="{{ countdown > 0 }}">{{ buttonText }}</button>
    
    <!-- 底部操作按钮 -->
    <view class="action-buttons">
      <button class="action-btn cigarette-btn" bindtap="goToCigarette">
        <image class="icon-svg" src="/assets/icons/cigarette-active.png" mode="aspectFit"></image>
        <text class="btn-text">电子烟</text>
      </button>
      <button class="action-btn share-btn" open-type="share">
        <image class="icon-svg" src="/assets/icons/share3.svg" mode="aspectFit"></image>
        <text class="btn-text">分享</text>
      </button>
    </view>
  </view>
</view>
