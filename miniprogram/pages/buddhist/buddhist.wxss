.container {
  min-height: 100vh;
  background: #ffffffd8;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 80rpx;
  text-align: center;
}

.cd-wrapper {
  width: 500rpx;
  height: 500rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 60rpx;
  position: relative;
}

.cd-container {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
}

.cd-container.rotating {
  animation: rotate 10s linear infinite;
}

@keyframes rotate {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.cd-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: radial-gradient(circle, #1a1a1a 20%, #333333 40%, #1a1a1a 60%, #000000 100%);
}

.text {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 80rpx;
  text-align: center;
}

.controls {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  gap: 40rpx;
}

.control-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10rpx);
  border-radius: 50%;
  width: 140rpx;
  height: 140rpx;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 226, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  transition: all 0.3s ease;
}

.control-btn::after {
  border: none;
}

.control-btn:active {
  transform: scale(0.95);
}

.control-btn.play-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  width: 160rpx;
  height: 160rpx;
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.4);
  border: 3rpx solid rgba(255, 255, 255, 0.8);
}

.control-btn.play-btn text {
  color: #FFFFFF;
}

.btn-icon {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 8rpx;
}

.control-btn.play-btn .btn-icon {
  width: 64rpx;
  height: 64rpx;
}

.control-btn text {
  font-size: 22rpx;
  color: #666666;
  font-weight: 500;
}

/* 链接地址显示区域 */
.link-section {
  margin-top: 60rpx;
  width: 90%;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.link-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.link-url {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
  word-break: break-all;
  background: #F5F5F5;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.copy-btn {
  width: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 16rpx;
  padding: 24rpx;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.3);
}

.copy-btn::after {
  border: none;
}

/* 留声机探针 */
.tonearm {
  position: absolute;
  top: 20rpx;
  right: 40rpx;
  width: 200rpx;
  height: 300rpx;
  transform-origin: 20rpx 20rpx;
  transition: transform 0.8s ease-in-out;
  z-index: 10;
}

.tonearm.playing {
  transform: rotate(25deg);
}

.tonearm-base {
  position: absolute;
  top: 0;
  left: 0;
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #C0C0C0 0%, #808080 100%);
  border-radius: 50%;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.3);
}

.tonearm-arm {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  width: 8rpx;
  height: 220rpx;
  background: linear-gradient(180deg, #A0A0A0 0%, #606060 100%);
  border-radius: 4rpx;
  transform-origin: top center;
  box-shadow: 2rpx 2rpx 6rpx rgba(0, 0, 0, 0.3);
}

.tonearm-head {
  position: absolute;
  top: 235rpx;
  left: 10rpx;
  width: 28rpx;
  height: 28rpx;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  border-radius: 50%;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.4);
}

.tonearm-head::after {
  content: '';
  position: absolute;
  bottom: -6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-top: 10rpx solid #FFA500;
}
