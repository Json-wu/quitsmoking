<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 戒烟成就卡片 -->
  <view class="achievement-card">
    <view class="achievement-main">
      <view class="days-display">
        <text class="days-number">{{ quitDays }}</text>
        <text class="days-unit">天</text>
      </view>
      <text class="days-label">已坚持戒烟</text>
    </view>

    <view class="achievement-stats">
      <view class="stat-item" bindtap="showEditModal">
        <text class="stat-icon">🚭</text>
        <view class="stat-info">
          <text class="stat-value">{{ savedCigarettes }}</text>
          <text class="stat-label">少抽香烟(根)</text>
        </view>
      </view>
      <view class="stat-item" bindtap="showEditModal">
        <text class="stat-icon">💰</text>
        <view class="stat-info">
          <text class="stat-value">{{ savedMoney }}</text>
          <text class="stat-label">节省金额(元)</text>
        </view>
      </view>
    </view>

    <!-- 分享按钮 -->
    <button class="share-btn" open-type="share">
      <image class="share-icon" src="/assets/icons/share.svg" mode="aspectFit"></image>
      <text class="share-text">分享经历</text>
    </button>
  </view>

  <!-- 我的勋章 -->
  <!--<view class="badges-section card" bindtap="goToBadges">
    <view class="section-header">
      <text class="section-title">我的勋章</text>
      <view class="header-right">
        <text class="badge-count">{{ badgeCount }}/{{ totalBadges }}</text>
        <image class="menu-arrow" src="/assets/icons/arrow-right.svg" mode="aspectFit"></image>
      </view>
    </view>
  </view>-->

  <!-- 功能入口 -->
  <view class="menu-section">
    <!--<view class="menu-item" bindtap="goToCertificate">
