      </view>
      <image class="menu-arrow" src="/assets/icons/arrow-right.svg" mode="aspectFit"></image>
    </view>-->
    <!--<view class="menu-item" bindtap="goToCollection">
      <view class="menu-left">
        <text class="menu-icon">⭐</text>
        <text class="menu-title">我的收藏</text>
      </view>
      <image class="menu-arrow" src="/assets/icons/arrow-right.svg" mode="aspectFit"></image>
    </view>-->
    <!--<view class="menu-item" bindtap="goToCalendar">
      <view class="menu-left">
        <text class="menu-icon">📅</text>
        <text class="menu-title">签到日历</text>
      </view>
      <image class="menu-arrow" src="/assets/icons/arrow-right.svg" mode="aspectFit"></image>
    </view>-->
    <!--<view class="menu-item" bindtap="goToSettings">
      <view class="menu-left">
        <text class="menu-icon">⚙️</text>
        <text class="menu-title">设置中心</text>
      </view>
      <image class="menu-arrow" src="/assets/icons/arrow-right.svg" mode="aspectFit"></image>
    </view>-->
    <view class="menu-item" bindtap="handleFeedback">
      <view class="menu-left">
        <text class="menu-icon">💬</text>
        <text class="menu-title">意见反馈</text>
      </view>
      <image class="menu-arrow" src="/assets/icons/arrow-right.svg" mode="aspectFit"></image>
    </view>
  </view>

  <!-- 小游戏快捷入口 -->
  <view class="games-section">
    <game-scroll title="休闲时刻" games="{{gameList}}" auto-scroll="{{true}}" scroll-speed="{{0.5}}"></game-scroll>
  </view>

  <!-- 编辑抽烟数据弹窗 - 从底部滑出 -->
  <view class="modal-mask {{ modalClosing ? 'closing' : '' }}" wx:if="{{ showModal }}" bindtap="hideEditModalWithSave">
    <view class="modal-content {{ modalClosing ? 'closing' : '' }}" catchtap="stopPropagation">
      <view class="modal-header">
        <view class="modal-close" bindtap="hideEditModalWithSave">✕</view>
      </view>
      
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">每天抽几根</text>
          <input 
            class="form-input" 
            type="number" 
            value="{{ dailyCigarettes }}" 
            bindinput="onDailyCigarettesInput"
            placeholder="0"
          />
        </view>
        
        <view class="form-item">
          <text class="form-label">一包烟多少钱</text>
          <input 
            class="form-input" 
            type="digit" 
            value="{{ cigarettePrice }}" 
            bindinput="onCigarettePriceInput"
            placeholder="0"
          />
        </view>
      </view>
    </view>
  </view>
</view>
