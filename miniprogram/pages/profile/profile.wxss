/* pages/profile/profile.wxss */

.container {
  min-height: 100vh;
  padding-bottom: 280rpx;
  background-color: #F5F7FA;
}

/* 用户信息区域 */
.user-section {
  margin: var(--spacing-md);
  padding: var(--spacing-lg);
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-light) 100%);
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: var(--spacing-md);
}

.user-detail {
  flex: 1;
}

.nickname {
  display: block;
  font-size: var(--font-xl);
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.user-badge {
  display: inline-flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 8rpx 16rpx;
  border-radius: 32rpx;
}

.badge-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.badge-text {
  font-size: 24rpx;
  color: #FFFFFF;
  margin-left: 8rpx;
}

/* 戒烟成就卡片 */
.achievement-card {
  margin: 24rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.achievement-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.achievement-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.achievement-level {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
}

.achievement-main {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 32rpx 0;
}

.days-display {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.days-number {
  font-size: 96rpx;
  font-weight: bold;
  color: #FFFFFF;
  line-height: 1;
}

.days-unit {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-left: 8rpx;
}

.days-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.achievement-stats {
  display: flex;
  justify-content: space-between;
  margin: 32rpx 0;
  padding: 24rpx 0;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.2);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.stat-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
  padding: 8rpx 20rpx;
  background: rgba(197, 205, 239, 0.1);
  border: 2rpx solid rgba(102, 126, 234, 0.3);
  border-radius: 24rpx;
  display: inline-block;
}

.stat-label {
  font-size: 20rpx;
  color: #ffffffdd;
  text-align: center;
}

.share-btn {
  width: 100%;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
}

.share-btn::after {
  border: none;
}

.share-icon {
  width: 48rpx;
  height: 48rpx;
}

.share-text {
  margin-left: 12rpx;
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* 签到统计 */
.checkin-section {
  margin: 24rpx;
}

/* 数据统计 */
.stats-section {
  margin: var(--spacing-md);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--spacing-md);
}

.stat-card {
  background-color: var(--bg-white);
  border-radius: var(--radius-md);
  padding: var(--spacing-lg) var(--spacing-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow-sm);
}

.stat-number {
  font-size: var(--font-xxl);
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

/* 我的勋章 */
.badges-section {
  margin: 0 var(--spacing-md) var(--spacing-md);
}

.badges-section .section-header {
  margin-bottom: 0;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.section-title {
  font-size: var(--font-lg);
  font-weight: bold;
  color: var(--text-primary);
}

.header-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.badge-count {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

.badges-section .menu-arrow {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.6;
}

.badges-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--spacing-md);
}

.badge-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-md);
  background-color: var(--bg-gray);
  border-radius: var(--radius-md);
  transition: all var(--transition-base);
}

.badge-item.locked {
  opacity: 0.3;
}

.badge-emoji {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.badge-name {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  text-align: center;
}

/* 功能入口 */
.menu-section {
  margin: 0 var(--spacing-md) var(--spacing-md);
  background-color: var(--bg-white);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-lg) var(--spacing-md);
  border-bottom: 1rpx solid var(--border-light);
  transition: background-color var(--transition-fast);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: var(--bg-gray);
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: var(--spacing-md);
}

.menu-title {
  font-size: var(--font-md);
  color: var(--text-primary);
}

.menu-arrow {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.6;
}

/* 广告区域 */
.ad-section {
  margin: var(--spacing-md);
  display: flex;
  justify-content: center;
}

/* 小游戏区域 */
.games-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(20rpx);
  padding: 20rpx 24rpx;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.1);
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
}

/* 编辑弹窗 - 从底部滑出 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 9999;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.modal-content {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFFFF;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  max-height: 60vh;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

@keyframes slideDown {
  from {
    transform: translateY(0);
  }
  to {
    transform: translateY(100%);
  }
}

.modal-content.closing {
  animation: slideDown 0.3s ease forwards;
}

.modal-mask.closing {
  animation: fadeOut 0.3s ease forwards;
}

@keyframes fadeOut {
  from {
    opacity: 1;
  }
  to {
    opacity: 0;
  }
}

.modal-header {
  padding: 32rpx;
  text-align: center;
  position: relative;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.modal-close {
  position: absolute;
  right: 32rpx;
  top: 32rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #999999;
  line-height: 1;
}

.modal-body {
  padding: 32rpx;
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 30rpx;
  color: #333333;
  flex-shrink: 0;
  width: 200rpx;
}

.form-input {
  flex: 1;
  text-align: left;
  height: 60rpx;
  padding: 0 24rpx;
  border-radius: 8rpx;
  font-size: 32rpx;
}

.modal-footer {
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  text-align: center;
  font-size: 24rpx;
  color: #999999;
}
