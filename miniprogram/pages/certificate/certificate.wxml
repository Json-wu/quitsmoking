<!--pages/certificate/certificate.wxml-->
<view class="container">
  <!-- 证书预览区域 -->
  <view class="certificate-preview">
    <canvas 
      type="2d" 
      id="certificate-canvas" 
      class="certificate-canvas"
    ></canvas>
    <view class="preview-placeholder" wx:if="{{ loading }}">
      <text class="placeholder-icon">⏳</text>
      <text class="placeholder-text">正在生成您的专属证书...</text>
    </view>
  </view>

  <!-- 证书信息 -->
  <view class="certificate-info card">
    <view class="info-row">
      <text class="info-label">证书等级</text>
      <text class="info-value">{{ certificateLevel }}</text>
    </view>
    <view class="info-row">
      <text class="info-label">戒烟天数</text>
      <text class="info-value">{{ quitDays }}天</text>
    </view>
    <view class="info-row">
      <text class="info-label">获得日期</text>
      <text class="info-value">{{ certificateDate }}</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons">
    <button class="action-btn save-btn" bindtap="handleSave" disabled="{{ !hasGenerated }}">
      <text class="btn-text">保存到相册</text>
    </button>
    <button class="action-btn share-btn" open-type="share" disabled="{{ !hasGenerated }}">
      <text class="btn-text">分享证书</text>
    </button>
  </view>

  <!-- 证书等级说明 -->
  <view class="level-section card">
    <view class="section-title">证书等级说明</view>
    <view class="level-list">
      <view 
        class="level-item {{ item.unlocked ? 'unlocked' : 'locked' }}" 
        wx:for="{{ levels }}" 
        wx:key="level"
      >
        <view class="level-icon">{{ item.icon }}</view>
        <view class="level-detail">
          <text class="level-name">{{ item.name }}</text>
          <text class="level-days">{{ item.days }}天{{ item.level === 'grandmaster' ? '以上' : '' }}</text>
        </view>
        <view class="level-status">
          <text wx:if="{{ item.unlocked }}">✓</text>
          <text wx:else class="text-tertiary">未解锁</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 提示文字 -->
  <view class="tip-section">
    <text class="tip-text">💡 证书会根据您的戒烟天数自动更新</text>
  </view>
</view>
