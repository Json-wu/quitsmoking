<!--pages/certificate/certificate.wxml-->
<view class="container">
  <!-- 证书预览区域 -->
  <view class="certificate-preview">
    <canvas 
      type="2d" 
      id="certificate-canvas" 
      class="certificate-canvas"
    ></canvas>
    <view class="preview-placeholder" wx:if="{{ loading }}">
      <text class="placeholder-icon">⏳</text>
      <text class="placeholder-text">正在生成您的专属证书...</text>
    </view>
  </view>

  <!-- 证书信息 -->
  <view class="certificate-info card">
    <view class="info-row">
      <text class="info-label">戒烟天数</text>
      <text class="info-value">{{ quitDays }}天</text>
    </view>
    <view class="info-row">
      <text class="info-label">获得日期</text>
      <text class="info-value">{{ certificateDate }}</text>
    </view>
  </view>

  <!-- 模板切换 -->
  <view class="template-section card">
    <view class="section-title">选择证书模板</view>
    <view class="template-list">
      <view 
        class="template-item {{ currentTemplate === item.id ? 'active' : '' }}" 
        wx:for="{{ templates }}" 
        wx:key="id"
        bindtap="handleTemplateChange"
        data-template="{{ item.id }}"
      >
        <image class="template-image" src="{{ item.bgImage }}" mode="aspectFill"></image>
      </view>
    </view>
  </view>

  <!-- 分享按钮 -->
  <view class="action-buttons">
    <button class="action-btn share-btn" open-type="share" disabled="{{ !hasGenerated }}">
      <text class="btn-text">分享</text>
    </button>
  </view>

  <!-- 提示文字 -->
  <view class="tip-section">
    <text class="tip-text">💡 选择喜欢的模板，分享您的戒烟成就</text>
  </view>
</view>
