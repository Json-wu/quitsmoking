/* pages/certificate/certificate.wxss */

.container {
  min-height: 100vh;
  padding: var(--spacing-md);
  background-color: var(--bg-color);
}

/* 证书预览区域 */
.certificate-preview {
  margin-bottom: var(--spacing-md);
  position: relative;
}
.certificate-canvas {
  width: 100%;
  height: 400rpx;
  display: block;
  border-radius: var(--radius-md);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.preview-placeholder {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 2;
  pointer-events: none;
}

.placeholder-icon {
  font-size: 120rpx;
  margin-bottom: var(--spacing-md);
  opacity: 0.6;
}

.placeholder-text {
  font-size: var(--font-md);
  color: var(--text-secondary);
  text-align: center;
  opacity: 0.8;
}

/* 证书信息 */
.certificate-info {
  margin-bottom: var(--spacing-md);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-md) 0;
  border-bottom: 1rpx solid var(--border-light);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: var(--font-md);
  color: var(--text-secondary);
}

.info-value {
  font-size: var(--font-md);
  font-weight: var(--font-medium);
  color: var(--text-primary);
}

/* 模板切换 */
.template-section {
  margin-bottom: var(--spacing-md);
}

.section-title {
  font-size: var(--font-md);
  color: var(--text-primary);
  margin-bottom: var(--spacing-md);
}

.template-list {
  display: flex;
  flex-direction: row;
  gap: var(--spacing-md);
  justify-content: space-between;
}

.template-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx;
  background-color: var(--bg-gray);
  border-radius: var(--radius-md);
  border: 3rpx solid transparent;
  transition: all var(--transition-base);
  cursor: pointer;
  overflow: hidden;
}

.template-item.active {
  border-color: var(--primary-color);
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 226, 0.3);
}

.template-image {
  width: 100%;
  height: 180rpx;
  border-radius: var(--radius-sm);
  display: block;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  flex-direction: row;
  gap: var(--spacing-md);
  margin-bottom: var(--spacing-md);
  margin-top: var(--spacing-md);
}

.action-btn {
  flex: 1;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-lg);
  border: none;
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-base);
}

.action-btn::after {
  border: none;
}

.action-btn:active:not([disabled]) {
  transform: scale(0.98);
}

.action-btn[disabled] {
  opacity: 0.5;
}

.share-btn {
  background: linear-gradient(135deg, #4A90E2 0%, #357ABD 100%);
}

.btn-text {
  font-size: var(--font-lg);
  color: #FFFFFF;
  font-weight: var(--font-medium);
}

/* 提示文字 */
.tip-section {
  text-align: center;
  padding: var(--spacing-md);
}

.tip-text {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}
