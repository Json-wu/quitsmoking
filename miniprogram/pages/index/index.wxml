<!--pages/index/index.wxml-->
<view class="container">
  <!-- 顶部功能图标 -->
  <view class="top-icons">
    <view class="top-icon-item" bindtap="goToCalendar">
        <image class="icon-svg" src="/assets/icons/dashboard.svg" mode="aspectFit"></image>
      <text class="icon-label">看板</text>
    </view>
    <view class="top-icon-item" bindtap="goToRefuse">
        <image class="icon-svg" src="/assets/icons/shield.svg" mode="aspectFit"></image>
      <text class="icon-label">护盾</text>
    </view>
    <view class="top-icon-item" bindtap="goToBreathing">
        <image class="icon-svg" src="/assets/icons/breath.svg" mode="aspectFit"></image>
      <text class="icon-label">呼吸</text>
    </view>
    <button class="top-icon-item top-icon-btn" open-type="share">
        <image class="icon-svg" src="/assets/icons/share.svg" mode="aspectFit"></image>
      <text class="icon-label">分享</text>
    </button>
  </view>

  <!-- 签到统计提示 -->
  <view class="checkin-stats-tip">
     <image class="icon-svg" src="/assets/icons/groups.svg" mode="aspectFit"></image>
    <text class="stats-text">今日{{ todayCheckinCount }}人签到戒烟</text>
  </view>

  <!-- 签到卡片 -->
  <view class="checkin-card">
    <view class="checkin-user">
      <text class="user-icon">👨‍⚕️</text>
      <text class="user-title">戒烟达人</text>
    </view>
    <button 
      class="checkin-btn {{ hasCheckedToday ? 'checked' : '' }}" 
      bindtap="handleCheckin"
    >
      {{ hasCheckedToday ? '今日已签到' : '签到' }}
    </button>
  </view>

  <!-- 功能网格 -->
  <view class="function-grid">
     <view class="function-item" bindtap="goToCertificate">
       <image class="icon-svg" src="/assets/icons/clendar.svg" mode="aspectFit"></image>
      <view class="date-info">
        <text class="date-text">{{ quitDate }}</text>
        <text class="date-label">荣誉证书</text>
      </view>
    </view>
    <view class="function-item" bindtap="goToCalendar">
      <view class="quit-days-badge">
        <text class="badge-number">{{ quitDays }}</text>
      </view>
      <view class="quit-info">
        <text class="quit-label">戒烟{{ quitDays }}天</text>
        <text class="quit-sublabel">明天有惊喜</text>
      </view>
    </view>
    <view class="function-item" bindtap="goToCamp">
      <image class="icon-svg" src="/assets/icons/faction.svg" mode="aspectFit"></image>
      <view class="function-text">
        <text class="func-title">戒烟阵营</text>
        <text class="func-desc">学习与分享</text>
      </view>
    </view>
    <!--<view class="function-item" bindtap="goToSettings">
      <image class="icon-svg" src="/assets/icons/plan.svg" mode="aspectFit"></image>
      <view class="function-text">
        <text class="func-title">添加计划</text>
        <text class="func-desc">制定周期提醒</text>
      </view>
      <view class="func-badge">热</view>
    </view>
    <view class="function-item" bindtap="goToMethods">
      <image class="icon-svg" src="/assets/icons/stop.svg" mode="aspectFit"></image>
      <view class="function-text">
        <text class="func-title">戒烟方法</text>
        <text class="func-desc">90%用户推荐</text>
      </view>
    </view>-->
    <view class="function-item" bindtap="goToProfile">
      <image class="icon-svg" src="/assets/icons/total.svg" mode="aspectFit"></image>
      <view class="function-text">
        <text class="func-title">我的数据</text>
        <text class="func-desc">数据分析统计</text>
      </view>
      <view class="func-badge">热</view>
    </view>
  </view>

  <!-- 缓解烟瘾 -->
  <view class="relief-section">
    <view class="relief-header">
      <text class="relief-title">缓解烟瘾</text>
      <button class="relief-btn" bindtap="goToBuddhist">前往佛性戒烟</button>
    </view>
    <view class="relief-canvas-wrapper">
      <canvas 
        type="2d" 
        id="relief-cigarette-canvas" 
        class="relief-cigarette-canvas"
        bindtap="goToCigarette"
      ></canvas>
    </view>
  </view>

  <!-- Banner广告 -->
  <!-- <view class="ad-section">
    <ad unit-id="adunit-xxxxxxxxxxxxxxxx" ad-type="banner" ad-theme="white"></ad>
  </view> -->

  <!-- 小游戏快捷入口 -->
  <view class="games-section">
    <game-scroll title="休闲时刻" games="{{gameList}}" auto-scroll="{{true}}" scroll-speed="{{0.5}}"></game-scroll>
  </view>
</view>
