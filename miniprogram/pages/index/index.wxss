/* pages/index/index.wxss */

.container {
  min-height: 100vh;
  padding-bottom: 280rpx;
  background: linear-gradient(180deg, #4A90E2 0%, #6BA3E8 30%, #FFFFFF 70%);
  padding-top: 200rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
}

/* ==================== 顶部功能图标 ==================== */
.top-icons {
  display: flex;
  justify-content: space-around;
  margin-bottom: 24rpx;
}

.top-icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.icon-svg {
  width: 64rpx;
  height: 64rpx;
}

.icon-label {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.top-icon-btn {
  background: transparent !important;
  border: none;
  padding: 0;
  margin: 0;
  line-height: inherit;
  overflow: visible;
  width: 60px !important;
  min-width: 0;
  border-radius: 0;
  font-size: inherit;
  color: inherit;
  text-align: inherit;
  margin: 0 !important;
}

.top-icon-btn::after {
  border: none;
  display: none;
}

/* ==================== 签到统计提示 ==================== */
.checkin-stats-tip {
  text-align: center;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stats-icon {
  font-size: 28rpx;
}

.stats-text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* ==================== 签到卡片 ==================== */
.checkin-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 20rpx 32rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.checkin-user {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.user-icon {
  font-size: 48rpx;
}

.user-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.checkin-btn {
  background: linear-gradient(135deg, #4A90E2 0%, #357ABD 100%);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 226, 0.3);
  width: 240rpx !important;
  margin-left: 0 !important;
  margin-right: 0 !important;
}

.checkin-btn::after {
  border: none;
}

.checkin-btn.checked {
  background: #6fadead3;
  color: #FFFFFF;
  box-shadow: none;
}

/* ==================== 日期卡片 ==================== */
.date-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.date-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.date-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #4A90E2 0%, #357ABD 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.date-icon {
  font-size: 40rpx;
}

.date-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.date-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.date-label {
  font-size: 24rpx;
  color: #999999;
}

.date-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.quit-days-badge {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #89b7ff 0%, #89b7ff 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.badge-number {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.quit-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.quit-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.quit-sublabel {
  font-size: 24rpx;
  color: #999999;
}

/* ==================== 功能网格 ==================== */
.function-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.function-item {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 12rpx 18rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  position: relative;
}

.function-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.function-icon.blue {
  background: linear-gradient(135deg, #4A90E2 0%, #357ABD 100%);
}

.func-emoji {
  font-size: 36rpx;
}

.function-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
}

.func-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.func-desc {
  font-size: 22rpx;
  color: #999999;
}

.func-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: #FF6B6B;
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

/* ==================== 签到记录 ==================== */
.checkin-record {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.record-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.record-title {
  font-size: 32rpx;
  font-weight: 400;
  color: #333333;
}

.record-tip {
  margin-left: 20rpx;
  font-size: 24rpx;
  color: #4A90E2;
  text-decoration: underline;
}

.record-tabs {
  display: flex;
  gap: 16rpx;
  margin-left: auto;
}

.tab-item {
  font-size: 26rpx;
  color: #999999;
  padding: 8rpx 16rpx;
}

.tab-item.active {
  color: #4A90E2;
  font-weight: 600;
  background: rgba(74, 144, 226, 0.1);
  border-radius: 12rpx;
}

.record-calendar {
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
}

.calendar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.calendar-emoji {
  font-size: 48rpx;
}

.calendar-day {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.calendar-label {
  font-size: 20rpx;
  color: #999999;
}

/* ==================== 缓解烟瘾 ==================== */
.relief-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.relief-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.relief-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.relief-btn {
  font-size: 24rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 40rpx;
  padding: 12rpx 18rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
  margin: 0 !important;
  width: 240rpx !important;
}

.relief-btn::after {
  border: none;
}

.relief-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
}

.relief-canvas-wrapper {
  width: 100%;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.relief-cigarette-canvas {
  width: 100%;
  height: 120rpx;
}

/* ==================== 广告区域 ==================== */
.ad-section {
  margin-top: 20rpx;
  display: flex;
  justify-content: center;
}

/* ==================== 小游戏区域 ==================== */
.games-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(20rpx);
  padding: 32rpx 40rpx;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.1);
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
}

/* ==================== 日期选择弹窗 ==================== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.modal-content {
  width: 600rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  padding: 40rpx;
  text-align: center;
  border-bottom: 1rpx solid #F0F0F0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.modal-body {
  padding: 40rpx;
}

.date-picker {
  padding: 24rpx;
  background-color: #F5F5F5;
  border-radius: 16rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333333;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #F0F0F0;
}

.modal-button {
  flex: 1;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 28rpx;
  background-color: transparent;
  border: none;
  border-radius: 0;
}

.modal-button::after {
  border: none;
}

.modal-button.cancel {
  color: #999999;
  border-right: 1rpx solid #F0F0F0;
}

.modal-button.confirm {
  color: #4A90E2;
  font-weight: bold;
}
