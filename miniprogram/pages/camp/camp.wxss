.container {
  min-height: 100vh;
  background: #ffffffd8;
  padding: 40rpx 40rpx 200rpx;
  display: flex;
  flex-direction: column;
}

/* 步骤区域 */
.steps {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
  margin-bottom: 40rpx;
}

.step-item {
  display: flex;
  gap: 24rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.step-number {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
  flex-shrink: 0;
}

.step-content {
  flex: 1;
}

.step-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.step-desc {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.wechat-id {
  font-size: 28rpx;
  font-weight: bold;
  color: #667eea;
  text-decoration: underline;
  padding: 4rpx 8rpx;
  border-radius: 8rpx;
  transition: all 0.3s ease;
}

.wechat-id:active {
  background: #F0F0FF;
  transform: scale(0.98);
}

.copy-btn {
  width: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 16rpx;
  padding: 24rpx;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.3);
}

.copy-btn::after {
  border: none;
}

.step-image {
  width: 100%;
  height: 300rpx;
  border-radius: 12rpx;
  background: #F5F5F5;
}

/* 小游戏区域 */
.games-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(20rpx);
  padding: 32rpx 40rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.1);
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
}
